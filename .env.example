# =============================================================================
# Școala de Fotbal Dan Matei — environment template
# Copy this to `.env.local` and fill in real values from your Supabase project.
# =============================================================================

# --- Supabase (browser + server) ---------------------------------------------
# Anon key is safe to ship to the browser; service role is server-only.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Server-only: NEVER prefix with VITE_, NEVER expose to the browser.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...same-as-above...
SUPABASE_SERVICE_ROLE=eyJhbGciOi...service-role-key-keep-secret...

# --- App config --------------------------------------------------------------
# Origin used for password-reset / invite redirects.
VITE_APP_URL=http://localhost:3030

# --- ElevenLabs Conversational AI -------------------------------------------
# Server-only. Used by /api/ai/start-conversation and /api/ai/webhook.
# Get the key from https://elevenlabs.io/app/settings/api-keys
# Default agent ID: the academy-wide assistant used when a trainer hasn't
# been linked to a specific agent. Each trainer can override via
# trainers.elevenlabs_agent_id (set from /admin or /antrenor).
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_DEFAULT_AGENT_ID=agent_...
# Optional but recommended — set the same value in the ElevenLabs webhook
# config so /api/ai/webhook can reject spoofed payloads.
ELEVENLABS_WEBHOOK_SECRET=

# --- WhatsApp Business Cloud API --------------------------------------------
# Server-only. Used by /api/whatsapp/send-welcome.
# Get these from Meta Business Manager → WhatsApp → Configuration.
# WHATSAPP_PHONE_ID is the numeric phone-number id, NOT the phone number.
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0

# --- AI-call lead flow (Pipecat + LiveKit + Evolution API) ------------------
# See docs/OPERATIONALIZE.md for the full deploy guide.

# Signs the /apel/<token> links. Long random string.
LEAD_LINK_SIGNING_SECRET=

# WhatsApp via Evolution API (open-source, self-hosted). Preferred over Meta.
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=academia

# LiveKit WebRTC server — local docker-compose defaults shown
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevse
LIVEKIT_AGENT_NAME=danmatei-voice-agent

# Direct provider keys for services/voice-agent.
# Set on Fly via `flyctl secrets set` — not used by Vercel.
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Pipecat voice agent endpoint + auth
VOICE_AGENT_SPAWN_URL=http://localhost:8080/spawn
VOICE_AGENT_AUTH_TOKEN=
PIPECAT_WEBHOOK_SECRET=

# Local-model sizing
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
WHISPER_MODEL=medium
PIPER_VOICE=ro_RO-mihai-medium
MAX_CALL_SECONDS=360

# Where the voice agent posts its end-of-call webhook
API_BASE=https://danmatei.vercel.app

# Trainer phones (optional) for the WhatsApp summary fan-out
TRAINER_PHONE_T_SOPI=
TRAINER_PHONE_T_KELEMEN=
TRAINER_PHONE_T_DAN=

# Caddy public host (optional, for TLS on the voice stack)
PUBLIC_HOST=
PUBLIC_BASE_URL=https://danmatei.vercel.app

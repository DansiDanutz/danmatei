{
  "expo": {
    "name": "Dan Matei",
    "slug": "danmatei-mobile",
    "scheme": "danmatei",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b1020"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.danmatei.mobile"
    },
    "android": {
      "package": "com.danmatei.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0b1020"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
